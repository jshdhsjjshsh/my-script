task.spawn(function()
while isFusing do
local cnts={}
for _,it in pairs(p._Inventory:GetChildren())do
local isFav=false
if noFuse then pcall(function()isFav=it:GetAttribute("Favorite")end)end
if not isFav then cnts[it.Name]=(cnts[it.Name]or 0)+1 end
end
for name,count in pairs(cnts)do
if count>=5 then
local items={}
for _,it in pairs(p._Inventory:GetChildren())do
if it.Name==name and #items<5 then
local isFav=false
if noFuse then pcall(function()isFav=it:GetAttribute("Favorite")end)end
if not isFav then table.insert(items,it)end
end
end
if #items>=5 then
pcall(function()ev.Fuse:InvokeServer("Fuse",items,false)end)
showNotif("🔄 Фьюз",name.." x5 → 1",false)
end
break
end
end
wait(1.5)
end
end)
else
fuseBtn.Text="🔄 АВТО ФЮЗ: ВЫКЛ"
fuseBtn.BackgroundColor3=Color3.fromRGB(80,50,50)
end
