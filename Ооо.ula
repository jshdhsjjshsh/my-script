}
local curTheme="Dark"

local function applyTheme()
main.BackgroundColor3=themes[curTheme].bg
tabBar.BackgroundColor3=themes[curTheme].btn
for _,v in pairs(tabBtns)do
v.TextColor3=themes[curTheme].accent
if v.BackgroundTransparency~=0.2 then v.BackgroundColor3=themes[curTheme].btn end
end
if tabBtns[curTab]then tabBtns[curTab].BackgroundColor3=themes[curTheme].accent end
content.ScrollBarImageColor3=themes[curTheme].accent
end

local function updateBal()
local stars=p:FindFirstChild("_StarsValue")
local ton=p:FindFirstChild("_TONValue")
local gems=p:FindFirstChild("_GemsValue")
local snow=p:FindFirstChild("_SnowflakesValue")
local suns=p:FindFirstChild("_Suns")
balL.Text="⭐"..(stars and stars.Value or 0).."  💠"..(ton and ton.Value or 0).."  💎"..(gems and gems.Value or 0).."  ❄️"..(snow and snow.Value or 0).."  ☀️"..(suns and suns.Value or 0)
end
updateBal()
if p:FindFirstChild("_StarsValue")then p._StarsValue.Changed:Connect(updateBal)end
if p:FindFirstChild("_TONValue")then p._TONValue.Changed:Connect(updateBal)end
if p:FindFirstChild("_GemsValue")then p._GemsValue.Changed:Connect(updateBal)end
if p:FindFirstChild("_SnowflakesValue")then p._SnowflakesValue.Changed:Connect(updateBal)end
if p:FindFirstChild("_Suns")then p._Suns.Changed:Connect(updateBal)end

local function showNotif(title,text,isDrop)
local n=Instance.new("Frame")
n.Size=UDim2.new(0,320,0,55)
n.Position=UDim2.new(0.5,-160,0,-65)
n.BackgroundColor3=Color3.fromRGB(20,25,40)
n.BackgroundTransparency=0.1
n.BorderSizePixel=0
n.Parent=gui
local nc=Instance.new("UICorner")nc.CornerRadius=UDim.new(0,10)nc.Parent=n
if isDrop then
local nb=Instance.new("UIStroke")nb.Thickness=2nb.Color=Color3.fromRGB(255,150,50)nb.Parent=n
end
local tl=Instance.new("TextLabel")tl.Size=UDim2.new(1,-10,0,22)tl.Position=UDim2.new(0,5,0,5)tl.Text=title tl.TextColor3=isDrop and Color3.fromRGB(255,150,50)or Color3.fromRGB(0,255,255)tl.BackgroundTransparency=1tl.Font=Enum.Font.GothamBold tl.TextSize=12tl.TextXAlignment=Enum.TextXAlignment.Left tl.Parent=n
local tx=Instance.new("TextLabel")tx.Size=UDim2.new(1,-10,0,25)tx.Position=UDim2.new(0,5,0,28)tx.Text=text tx.TextColor3=Color3.new(1,1,1)tx.BackgroundTransparency=1tx.Font=Enum.Font.Gotham tx.TextSize=10tx.TextWrapped=true tx.Parent=n
ts:Create(n,TweenInfo.new(0.3,Enum.EasingStyle.Back),{Position=UDim2.new(0.5,-160,0,10)}):Play()
wait(3.5)
ts:Create(n,TweenInfo.new(0.3,Enum.EasingStyle.Back),{Position=UDim2.new(0.5,-160,0,-65)}):Play()
wait(0.3)n:Destroy()
end

