local ttl=Instance.new("TextLabel")ttl.Size=UDim2.new(1,-10,0,35)ttl.Position=UDim2.new(0,5,0,y)ttl.Text="🎨 ВЫБЕРИ ТЕМУ"ttl.TextColor3=themes[curTheme].accent ttl.BackgroundTransparency=1ttl.Font=Enum.Font.GothamBold ttl.TextSize=15ttl.Parent=content
y=y+40
local themeList={"Dark","Blue","Red","Green","Purple"}
local colors={Color3.fromRGB(15,20,35),Color3.fromRGB(20,30,50),Color3.fromRGB(40,20,20),Color3.fromRGB(20,40,20),Color3.fromRGB(30,20,45)}
for i,th in pairs(themeList)do
local btn=Instance.new("TextButton")btn.Size=UDim2.new(0.18,-5,0,40)btn.Position=UDim2.new((i-1)*0.2,5,0,y)btn.Text=th btn.TextColor3=Color3.fromRGB(0,255,255)btn.BackgroundColor3=colors[i]btn.BorderSizePixel=0btn.Font=Enum.Font.GothamBold btn.TextSize=12btn.Parent=content
local btnc=Instance.new("UICorner")btnc.CornerRadius=UDim.new(0,8)btnc.Parent=btn
btn.MouseButton1Click:Connect(function()
curTheme=th
applyTheme()
showNotif("🎨 Тема",th,false)
end)
end
content.CanvasSize=UDim2.new(0,0,0,y+50)

elseif curTab=="Info"then
local ttl=Instance.new("TextLabel")ttl.Size=UDim2.new(1,-10,0,35)ttl.Position=UDim2.new(0,5,0,y)ttl.Text="ℹ️ ИНФОРМАЦИЯ"ttl.TextColor3=themes[curTheme].accent ttl.BackgroundTransparency=1ttl.Font=Enum.Font.GothamBold ttl.TextSize=15ttl.Parent=content
y=y+40
local inf=Instance.new("TextLabel")inf.Size=UDim2.new(1,-10,0,120)inf.Position=UDim2.new(0,5,0,y)inf.Text="СОЗДАТЕЛЬ: TROTULOV39\n\nВЕРСИЯ: 8.3 ULTIMATE\n\nДЛЯ: NFT BATTLE\n\nВСЕ ФУНКЦИИ РАБОТАЮТ АВТОМАТИЧЕСКИ"inf.TextColor3=themes[curTheme].text inf.BackgroundTransparency=1inf.Font=Enum.Font.Gotham inf.TextSize=12inf.TextWrapped=true inf.Parent=content
y=y+130
local stats=Instance.new("TextLabel")stats.Size=UDim2.new(1,-10,0,80)stats.Position=UDim2.new(0,5,0,y)stats.Text="📊 СТАТИСТИКА\n\nКейсов открыто: "..(p._CasesOpened and p._CasesOpened.Value or 0).."\nАпгрейдов сделано: "..(p._UpgradesMade and p._UpgradesMade.Value or 0)stats.TextColor3=Color3.fromRGB(200,200,200)stats.BackgroundTransparency=1stats.Font=Enum.Font.Gotham stats.TextSize=11stats.TextWrapped=true stats.Parent=content
content.CanvasSize=UDim2.new(0,0,0,y+90)
end
end

applyTheme()
loadTab()
print("✅ NFT BATTLE ULTIMATE V8.3 LOADED")
