startBtn.MouseButton1Click:Connect(function()
isRunning=not isRunning
if isRunning then
startBtn.Text="⏹ СТОП"
startBtn.BackgroundColor3=Color3.fromRGB(100,50,50)
task.spawn(function()
while isRunning do
for name,count in pairs(caseCounts)do
if count>0 and isRunning then
for i=1,count do
if not isRunning then break end
local s,items=pcall(function()return ev.OpenCase:InvokeServer(name,1)end)
if s and items then
if type(items)=="table"then
for _,it in pairs(items)do
local isFav=false
for _,fv in pairs(favList)do if it==fv then isFav=true break end end
if isFav then
pcall(function()ev.Favorite:InvokeServer(it,true)end)
showNotif("⭐ В ИЗБРАННОМ",it,false)
elseif isAutoSell then
pcall(function()ev.Inventory:FireServer("Sell",it)end)
showNotif("🛒 ПРОДАНО",it,false)
else
showNotif("📦 ПОЛУЧЕНО",it,false)
end
local pr=nftPrices[it]or 0
if pr>=1000000000 then showNotif("🔥 МЕГА ДРОП","⭐"..pr,true)end
end
end
end
wait(0.4)
end
end
end
wait(1)
end
end)
else
startBtn.Text="▶ СТАРТ ОТКРЫТИЕ"
startBtn.BackgroundColor3=Color3.fromRGB(50,100,50)
end
end)
