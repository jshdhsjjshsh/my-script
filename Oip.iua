local favorites = {} -- Избранное
local searchQuery = ""
local searchMode = "name" -- "name" или "content"
local rootVisible = true

-- ===== ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ =====
local function getIcon(obj)
    local className = obj.ClassName
    local icons = {
        Folder = "📁", Configuration = "📁", Model = "🏗️",
        Part = "🧱", MeshPart = "🧱", UnionOperation = "🧱",
        Script = "📜", LocalScript = "🟢", ModuleScript = "📦",
        RemoteEvent = "⚡", RemoteFunction = "🔧",
        BindableEvent = "📡", BindableFunction = "🔩",
        StringValue = "🔤", IntValue = "🔢", NumberValue = "🔢",
        BoolValue = "☑️", Color3Value = "🎨", Vector3Value = "📐",
        CFrameValue = "🎯", ObjectValue = "🔗",
        Sound = "🔊", Animation = "🎬", Tool = "🔨",
        Decal = "🖼️", Texture = "🖼️", ImageLabel = "🖼️", ImageButton = "🖼️",
        ScreenGui = "🪟", SurfaceGui = "🪟",
        Frame = "⬜", TextLabel = "📝", TextButton = "📝",
        UIListLayout = "📏", UIGridLayout = "📏"
    }
    return icons[className] or "📄"
end

local function getObjectContent(obj)
    local className = obj.ClassName
    if className == "Script" or className == "LocalScript" or className == "ModuleScript" then
        return obj.Source or "", "text"
    elseif className == "StringValue" then
        return obj.Value or "", "text"
    elseif className == "IntValue" or className == "NumberValue" then
        return tostring(obj.Value), "text"
    elseif className == "BoolValue" then
        return tostring(obj.Value), "text"
    elseif className == "Color3Value" then
        local c = obj.Value
        return string.format("Color3.new(%f, %f, %f)", c.R, c.G, c.B), "text"
    elseif className == "Vector3Value" then
        local v = obj.Value
        return string.format("Vector3.new(%f, %f, %f)", v.X, v.Y, v.Z), "text"
    elseif className:find("Texture") or className:find("Decal") or className:find("Image") then
        return obj.Texture or obj.Image or "", "image"
    end
    return "", "text"
end

