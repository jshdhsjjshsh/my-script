-- ===== УВЕДОМЛЕНИЯ =====
local function showNotification(text, color)
    color = color or CONFIG.Colors.Success
    local notif = Instance.new("Frame")
    notif.Size = UDim2.new(0, 300, 0, 40)
    notif.Position = UDim2.new(0.5, -150, 0, 10)
    notif.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
    notif.BackgroundTransparency = 0
    notif.BorderSizePixel = 0
    notif.Parent = game.Players.LocalPlayer.PlayerGui or game:GetService("CoreGui")
    
    local notifCorner = Instance.new("UICorner")
    notifCorner.CornerRadius = UDim.new(0, 6)
    notifCorner.Parent = notif
    
    local border = Instance.new("Frame")
    border.Size = UDim2.new(1, 0, 0, 3)
    border.BackgroundColor3 = color
    border.BorderSizePixel = 0
    border.Parent = notif
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, -10, 1, 0)
    textLabel.Position = UDim2.new(0, 10, 0, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = text
    textLabel.TextColor3 = CONFIG.Colors.Text
    textLabel.TextSize = 13
    textLabel.Font = Enum.Font.SourceSans
    textLabel.TextXAlignment = Enum.TextXAlignment.Left
    textLabel.Parent = notif
    
    notif.BackgroundTransparency = 1
    TweenService:Create(notif, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play()
    
    task.wait(2)
    TweenService:Create(notif, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
    task.wait(0.3)
    notif:Destroy()
end

-- ===== ОСНОВНАЯ ЛОГИКА =====
local function collectData(root, depth, path)
    depth = depth or 0
    path = path or ""
    local data = {
        obj = root,
        depth = depth,
        path = path,
        children = {},
        isOpen = false,
        isFolder = false,
        icon = getIcon(root),
        name = root.Name,
        className = root.ClassName,
        childCount = #root:GetChildren()
    }
    
    -- Определяем является ли папкой
    if root:IsA("Folder") or root:IsA("Configuration") or root:IsA("Model") or 
       (root:IsA("Instance") and #root:GetChildren() > 0 and not root:IsA("Script") and not root:IsA("LocalScript") and not root:IsA("ModuleScript")) then
        data.isFolder = true
        data.childCount = #root:GetChildren()
    end
    
    -- Восстанавливаем состояние открытости
    local key = path .. "/" .. root.Name
    if openFolders[key] ~= nil then
        data.isOpen = openFolders[key]
    end
    
    table.insert(allData, data)
    flatItems[root] = data
    
    if data.isFolder and data.isOpen then
        for _, child in ipairs(root:GetChildren()) do
            local childData = collectData(child, depth + 1, key)
            if childData then
                table.insert(data.children, childData)
            end
        end
    end
    
    return data
end

-- Функция поиска по содержимому
local function searchInContent(data, query)
    if not query or query == "" then return true end
    local lowerQuery = string.lower(query)
    
    if searchMode == "name" then
        return string.find(string.lower(data.name), lowerQuery, 1, true) ~= nil
    else -- content
        local content, _ = getObjectContent(data.obj)
        return string.find(string.lower(content), lowerQuery, 1, true) ~= nil
    end
end

local function rebuildVisibleTree(scrollFrame, treeLayout, dataItems)
    -- Очищаем дерево
    for _, child in ipairs(scrollFrame:GetChildren()) do
        if child:IsA("TextButton") or child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    if not dataItems or #dataItems == 0 then
        local emptyLabel = Instance.new("TextLabel")
        emptyLabel.Size = UDim2.new(1, 0, 0, 30)
        emptyLabel.BackgroundTransparency = 1
        emptyLabel.Text = "📭 Нет объектов для отображения"
        emptyLabel.TextColor3 = Color3.fromRGB(150, 150, 160)
        emptyLabel.TextSize = 13
        emptyLabel.Font = Enum.Font.SourceSans
        emptyLabel.Parent = scrollFrame
        return
    end
    
    local function createItemButton(data)
        if not searchInContent(data, searchQuery) then
            return nil
        end
        
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 24)
        btn.BackgroundColor3 = CONFIG.Colors.ItemBackground
        btn.BackgroundTransparency = 0.5
        btn.BorderSizePixel = 0
        btn.Text = ""
        btn.Parent = scrollFrame
        
        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 3)
        btnCorner.Parent = btn
        
        -- Hover эффект
        btn.MouseEnter:Connect(function()
            if btn.BackgroundTransparency == 0.5 then
                TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundTransparency = 0.2}):Play()
            end
        end)
        btn.MouseLeave:Connect(function()
            if btn.BackgroundTransparency == 0.2 then
                TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundTransparency = 0.5}):Play()
            end
        end)
        
        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, -10, 1, 0)
        label.Position = UDim2.new(0, 10 + data.depth * 15, 0, 0)
        label.BackgroundTransparency = 1
        label.Text = data.icon .. " " .. data.name
        label.TextColor3 = CONFIG.Colors.Text
        label.TextSize = 13
        label.Font = Enum.Font.SourceSans
        label.TextXAlignment = Enum.TextXAlignment.Left
        label.Parent = btn
        
        -- Индикатор количества дочерних элементов
        if data.isFolder and data.childCount > 0 then
            local countLabel = Instance.new("TextLabel")
            countLabel.Size = UDim2.new(0, 30, 1, 0)
            countLabel.Position = UDim2.new(1, -35, 0, 0)
            countLabel.BackgroundTransparency = 1
            countLabel.Text = "(" .. data.childCount .. ")"
            countLabel.TextColor3 = Color3.fromRGB(120, 120, 130)
            countLabel.TextSize = 11
            countLabel.Font = Enum.Font.SourceSans
            countLabel.TextXAlignment = Enum.TextXAlignment.Right
            countLabel.Parent = btn
        end
        
        -- Стрелка для папок
        if data.isFolder then
            local arrow = Instance.new("TextLabel")
            arrow.Size = UDim2.new(0, 20, 1, 0)
            arrow.Position = UDim2.new(0, -15, 0, 0)
            arrow.BackgroundTransparency = 1
            arrow.Text = data.isOpen and "▼" or "▶"
            arrow.TextColor3 = Color3.fromRGB(150, 150, 160)
            arrow.TextSize = 12
            arrow.Font = Enum.Font.SourceSans
            arrow.Parent = btn
        end
        
        -- Сохраняем данные в кнопке
        btn:SetAttribute("Data", data)
        
        return btn
    end
    
    -- Создаем кнопки для всех элементов
    local buttons = {}
    for _, data in ipairs(dataItems) do
        if data.isFolder and data.isOpen then
            -- Добавляем папку
            local btn = createItemButton(data)
            if btn then table.insert(buttons, btn) end
            
            -- Добавляем детей
            for _, child in ipairs(data.children) do
                local childBtn = createItemButton(child)
                if childBtn then table.insert(buttons, childBtn) end
            end
        else
            local btn = createItemButton(data)
            if btn then table.insert(buttons, btn) end
        end
    end
    
    -- Обновляем canvas
    local totalHeight = #buttons * 25 + 10
    scrollFrame.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
end

-- ===== ЗАГРУЗКА ДАННЫХ =====
local function loadEverything(ui)
    ui.LoadBtn.Text = "⏳ Загрузка..."
    ui.LoadBtn.BackgroundColor3 = Color3.fromRGB(200, 150, 0)
    ui.ProgressFrame.Visible = true
    ui.ProgressFrame.BackgroundTransparency = 0
    ui.ProgressBar.Size = UDim2.new(0, 0, 1, 0)
    
    task.spawn(function()
        allData = {}
        flatItems = {}
        
        local totalObjects = 0
        local processed = 0
        
        -- Собираем все объекты
        local function collectAll(obj, depth, path)
            depth = depth or 0
            path = path or ""
            totalObjects = totalObjects + 1
            
            local data = {
                obj = obj,
                depth = depth,
                path = path,
                children = {},
                isOpen = false,
                isFolder = false,
                icon = getIcon(obj),
                name = obj.Name,
                className = obj.ClassName,
                childCount = #obj:GetChildren()
            }
            
            if obj:IsA("Folder") or obj:IsA("Configuration") or obj:IsA("Model") or 
               (obj:IsA("Instance") and #obj:GetChildren() > 0 and not obj:IsA("Script") and not obj:IsA("LocalScript") and not obj:IsA("ModuleScript")) then
                data.isFolder = true
                data.isOpen = false
            end
            
            table.insert(allData, data)
            flatItems[obj] = data
            
            if processed % 400 == 0 then
                RunService.Stepped:Wait()
            end
            processed = processed + 1
            
            -- Обновляем прогресс
            if processed % 100 == 0 then
                local progress = math.min(processed / totalObjects, 1)
                ui.ProgressBar.Size = UDim2.new(progress, 0, 1, 0)
            end
            
            for _, child in ipairs(obj:GetChildren()) do
                collectAll(child, depth + 1, path .. "/" .. obj.Name)
            end
        end
        
        collectAll(game, 0, "")
        
        -- Загружаем избранное
        if isfolder and isfolder("studio_explorer_favorites.json") then
            local content = readfile("studio_explorer_favorites.json")
            if content then
                favorites = game:GetService("HttpService"):JSONDecode(content) or {}
            end
        end
        
        ui.ProgressBar.Size = UDim2.new(1, 0, 1, 0)
        ui.LoadBtn.Text = "✅ Загружено: " .. #allData .. " объектов"
        ui.LoadBtn.BackgroundColor3 = CONFIG.Colors.Success
        
        task.wait(0.5)
        ui.ProgressFrame.Visible = false
        ui.ProgressFrame.BackgroundTransparency = 1
        
        rebuildVisibleTree(ui.ScrollFrame, ui.TreeLayout, allData)
        showNotification("✅ Загружено: " .. #allData .. " объектов", CONFIG.Colors.Success)
    end)
end

