    WindowSize = UDim2.new(0, 360, 0, 480),
    MinWindowSize = UDim2.new(0, 360, 0, 100),
    EditorSize = UDim2.new(0, 420, 0, 360),
    Font = "Code",
    FontSize = 13,
    Colors = {
        Background = Color3.fromRGB(30, 30, 35),
        ItemBackground = Color3.fromRGB(40, 40, 45),
        Hover = Color3.fromRGB(50, 50, 55),
        Text = Color3.fromRGB(220, 220, 230),
        Accent = Color3.fromRGB(0, 120, 215),
        Success = Color3.fromRGB(0, 200, 80),
        Danger = Color3.fromRGB(220, 50, 50),
        Warning = Color3.fromRGB(255, 200, 50),
        Folder = Color3.fromRGB(255, 200, 50),
        Script = Color3.fromRGB(70, 160, 255),
        LocalScript = Color3.fromRGB(70, 220, 70),
        ModuleScript = Color3.fromRGB(180, 80, 255),
    }
}

-- ===== ГЛОБАЛЬНЫЕ ПЕРЕМЕННЫЕ =====
