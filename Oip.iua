-- RBX Studio‑Style File Explorer v3.1 (Улучшенная версия)
-- Добавлено:
-- 1. Сохранение состояния дерева (открытые папки сохраняются при обновлении)
-- 2. Экспорт дерева в JSON (сохранение структуры игры)
-- 3. Поиск по содержимому скриптов
-- 4. Избранное (Favorites) - быстрый доступ к важным объектам
-- 5. Клавиша Delete для удаления выбранного объекта
-- 6. Отображение количества дочерних элементов у папок
-- 7. Поддержка двойного клика для открытия/закрытия
-- 8. Экспорт скрипта в файл (через clipboard)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local Clipboard = setclipboard or toclipboard or function(text) 
    print("Clipboard not available, but here's the text:", text) 
end

-- ===== НАСТРОЙКИ =====
