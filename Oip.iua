    menu.Parent = ui.ScreenGui
    
    local menuCorner = Instance.new("UICorner")
    menuCorner.CornerRadius = UDim.new(0, 6)
    menuCorner.Parent = menu
    
    local shadow = Instance.new("ImageLabel")
    shadow.Size = UDim2.new(1, 20, 1, 20)
    shadow.Position = UDim2.new(0, -10, 0, -10)
    shadow.BackgroundTransparency = 1
    shadow.Image = "rbxassetid://1316045203"
    shadow.ImageTransparency = 0.8
    shadow.ScaleType = Enum.ScaleType.Slice
    shadow.SliceCenter = Rect.new(10, 10, 10, 10)
    shadow.Parent = menu
    
    local menuLayout = Instance.new("UIListLayout")
    menuLayout.Padding = UDim.new(0, 1)
    menuLayout.Parent = menu
    
    local function addMenuItem(text, callback)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 28)
        btn.BackgroundTransparency = 1
        btn.Text = "  " .. text
        btn.TextColor3 = CONFIG.Colors.Text
        btn.TextSize = 13
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.Font = Enum.Font.SourceSans
        btn.Parent = menu
        
        btn.MouseEnter:Connect(function()
            btn.BackgroundTransparency = 0.3
            btn.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
        end)
        btn.MouseLeave:Connect(function()
            btn.BackgroundTransparency = 1
        end)
        btn.MouseButton1Click:Connect(function()
            callback()
            menu:Destroy()
        end)
        
        return btn
    end
    
    addMenuItem("📋 Копировать содержимое", function()
        local content, type = getObjectContent(data.obj)
        if content and content ~= "" then
            Clipboard(content)
            showNotification("📋 Скопировано!", CONFIG.Colors.Success)
        else
            showNotification("❌ Нет содержимого для копирования", CONFIG.Colors.Danger)
        end
    end)
    
    -- Копировать ID для текстур
    if data.obj:IsA("Decal") or data.obj:IsA("Texture") or data.obj:IsA("ImageLabel") or data.obj:IsA("ImageButton") then
        addMenuItem("🖼️ Копировать ID текстуры", function()
            local id = data.obj.Texture or data.obj.Image or ""
            if id ~= "" then
                Clipboard(id)
                showNotification("🖼️ ID текстуры скопирован!", CONFIG.Colors.Success)
            end
        end)
    end
    
    -- Редактировать скрипт
    if data.obj:IsA("Script") or data.obj:IsA("LocalScript") or data.obj:IsA("ModuleScript") then
        addMenuItem("✏️ Редактировать", function()
            openScriptEditor(data.obj)
        end)
    end
    
    addMenuItem("📝 Копировать путь", function()
        local path = data.path .. "/" .. data.obj.Name
        Clipboard(path)
        showNotification("📝 Путь скопирован: " .. path, CONFIG.Colors.Warning)
    end)
    
    -- Добавить в избранное
    local isFavorite = false
    for _, fav in ipairs(favorites) do
        if fav == data.path .. "/" .. data.obj.Name then
            isFavorite = true
            break
        end
    end
    
    addMenuItem(isFavorite and "⭐ Убрать из избранного" or "⭐ Добавить в избранное", function()
        local path = data.path .. "/" .. data.obj.Name
        if isFavorite then
            for i, fav in ipairs(favorites) do
                if fav == path then
                    table.remove(favorites, i)
                    break
                end
            end
            showNotification("⭐ Убрано из избранного", CONFIG.Colors.Warning)
        else
            table.insert(favorites, path)
            showNotification("⭐ Добавлено в избранное", CONFIG.Colors.Success)
        end
        
        -- Сохраняем избранное
        if writefile then
            local json = game:GetService("HttpService"):JSONEncode(favorites)
            writefile("studio_explorer_favorites.json", json)
        end
    end)
    
    addMenuItem("🗑️ Удалить", function()
        local name = data.obj.Name
        data.obj:Destroy()
        showNotification("🗑️ Удалено: " .. name, CONFIG.Colors.Danger)
        rebuildVisibleTree(ui.ScrollFrame, ui.TreeLayout, allData)
    end)
    
    -- Авторазмер
    local count = #menu:GetChildren() - 2 -- minus shadow and layout
    menu.Size = UDim2.new(0, 200, 0, count * 29 + 2)
end

-- ===== РЕДАКТОР КОДА =====
local function openScriptEditor(script)
    local screenGui = game.Players.LocalPlayer.PlayerGui or game:GetService("CoreGui")
    
    -- Закрываем старый редактор
    for _, child in ipairs(screenGui:GetChildren()) do
        if child.Name == "ScriptEditor" then
            child:Destroy()
        end
    end
    
    local editor = Instance.new("Frame")
    editor.Name = "ScriptEditor"
    editor.Size = CONFIG.EditorSize
    editor.Position = UDim2.new(0.5, -210, 0.5, -180)
    editor.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
    editor.BackgroundTransparency = 0.05
    editor.BorderSizePixel = 0
    editor.Parent = screenGui
    
    local editorCorner = Instance.new("UICorner")
    editorCorner.CornerRadius = UDim.new(0, 8)
    editorCorner.Parent = editor
    
    local shadow = Instance.new("ImageLabel")
    shadow.Size = UDim2.new(1, 20, 1, 20)
    shadow.Position = UDim2.new(0, -10, 0, -10)
    shadow.BackgroundTransparency = 1
    shadow.Image = "rbxassetid://1316045203"
    shadow.ImageTransparency = 0.7
    shadow.ScaleType = Enum.ScaleType.Slice
    shadow.SliceCenter = Rect.new(10, 10, 10, 10)
    shadow.Parent = editor
    
    -- Заголовок
    local titleBar = Instance.new("Frame")
    titleBar.Size = UDim2.new(1, 0, 0, 35)
    titleBar.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
    titleBar.BackgroundTransparency = 1
    titleBar.BorderSizePixel = 0
    titleBar.Parent = editor
    
    local titleCorner = Instance.new("UICorner")
    titleCorner.CornerRadius = UDim.new(0, 8)
    titleCorner.Parent = titleBar
    
    local titleText = Instance.new("TextLabel")
    titleText.Size = UDim2.new(0.7, 0, 1, 0)
    titleText.Position = UDim2.new(0, 10, 0, 0)
    titleText.BackgroundTransparency = 1
    titleText.Text = "✏️ " .. script.Name
    titleText.TextColor3 = CONFIG.Colors.Text
    titleText.TextSize = 14
    titleText.TextXAlignment = Enum.TextXAlignment.Left
    titleText.Font = Enum.Font.SourceSansBold
    titleText.Parent = titleBar
    
    -- Кнопка закрытия
    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 30, 1, 0)
    closeBtn.Position = UDim2.new(1, -35, 0, 0)
    closeBtn.BackgroundTransparency = 1
    closeBtn.Text = "×"
    closeBtn.TextColor3 = CONFIG.Colors.Text
    closeBtn.TextSize = 20
    closeBtn.Font = Enum.Font.SourceSansBold
    closeBtn.Parent = titleBar
    
    closeBtn.MouseButton1Click:Connect(function()
        editor:Destroy()
    end)
    
    -- Редактор
    local textBox = Instance.new("TextBox")
    textBox.Size = UDim2.new(1, -10, 1, -80)
    textBox.Position = UDim2.new(0, 5, 0, 40)
    textBox.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    textBox.BackgroundTransparency = 1
    textBox.TextColor3 = CONFIG.Colors.Text
    textBox.TextSize = 13
    textBox.Font = Enum.Font.Code
    textBox.TextXAlignment = Enum.TextXAlignment.Left
    textBox.TextYAlignment = Enum.TextYAlignment.Top
    textBox.MultiLine = true
    textBox.ClearTextOnFocus = false
    textBox.Text = script.Source or ""
    textBox.Parent = editor
    
    local textCorner = Instance.new("UICorner")
    textCorner.CornerRadius = UDim.new(0, 4)
    textCorner.Parent = textBox
    
    -- Кнопки
    local btnFrame = Instance.new("Frame")
    btnFrame.Size = UDim2.new(1, 0, 0, 35)
    btnFrame.Position = UDim2.new(0, 0, 1, -35)
    btnFrame.BackgroundTransparency = 1
    btnFrame.Parent = editor
    
    local copyBtn = Instance.new("TextButton")
    copyBtn.Size = UDim2.new(0, 100, 1, 0)
    copyBtn.Position = UDim2.new(0, 5, 0, 0)
    copyBtn.BackgroundColor3 = CONFIG.Colors.Accent
    copyBtn.BackgroundTransparency = 1
    copyBtn.Text = "📋 Копировать"
    copyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    copyBtn.TextSize = 13
    copyBtn.Font = Enum.Font.SourceSansBold
    copyBtn.Parent = btnFrame
    
    local copyCorner = Instance.new("UICorner")
    copyCorner.CornerRadius = UDim.new(0, 4)
    copyCorner.Parent = copyBtn
    
    local saveBtn = Instance.new("TextButton")
    saveBtn.Size = UDim2.new(0, 100, 1, 0)
    saveBtn.Position = UDim2.new(0, 110, 0, 0)
    saveBtn.BackgroundColor3 = CONFIG.Colors.Success
    saveBtn.BackgroundTransparency = 1
    saveBtn.Text = "💾 Сохранить"
    saveBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    saveBtn.TextSize = 13
    saveBtn.Font = Enum.Font.SourceSansBold
    saveBtn.Parent = btnFrame
    
    local saveCorner = Instance.new("UICorner")
    saveCorner.CornerRadius = UDim.new(0, 4)
    saveCorner.Parent = saveBtn
    
    -- Экспорт в файл (если поддерживается)
    if writefile then
        local exportBtn = Instance.new("TextButton")
        exportBtn.Size = UDim2.new(0, 100, 1, 0)
        exportBtn.Position = UDim2.new(0, 215, 0, 0)
        exportBtn.BackgroundColor3 = Color3.fromRGB(200, 150, 0)
        exportBtn.BackgroundTransparency = 1
        exportBtn.Text = "📤 Экспорт"
        exportBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        exportBtn.TextSize = 13
        exportBtn.Font = Enum.Font.SourceSansBold
        exportBtn.Parent = btnFrame
        
        local exportCorner = Instance.new("UICorner")
        exportCorner.CornerRadius = UDim.new(0, 4)
        exportCorner.Parent = exportBtn
        
        exportBtn.MouseButton1Click:Connect(function()
            local path = "exported_script_" .. script.Name .. "_" .. os.time() .. ".lua"
            writefile(path, textBox.Text)
            showNotification("📤 Экспортировано в: " .. path, CONFIG.Colors.Success)
        end)
    end
    
    copyBtn.MouseButton1Click:Connect(function()
        Clipboard(textBox.Text)
        showNotification("📋 Код скопирован!", CONFIG.Colors.Success)
    end)
    
    saveBtn.MouseButton1Click:Connect(function()
        local success, err = pcall(function()
            script.Source = textBox.Text
        end)
        if success then
            showNotification("✅ Сохранено!", CONFIG.Colors.Success)
        else
            showNotification("❌ Ошибка сохранения: " .. err, CONFIG.Colors.Danger)
        end
    end)
    
    -- Горячие клавиши
    local connection
    connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        
        if input.KeyCode == Enum.KeyCode.Escape then
            editor:Destroy()
            connection:Disconnect()
        elseif input.KeyCode == Enum.KeyCode.S and input:IsModifierKeyActive(Enum.ModifierKey.Control) then
            saveBtn.MouseButton1Click:Fire()
        end
    end)
    
    editor.AncestryChanged:Connect(function()
        if not editor.Parent then
            connection:Disconnect()
        end
    end)
end

-- ===== HOTKEYS =====
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.E and input:IsModifierKeyActive(Enum.ModifierKey.Control) and input:IsModifierKeyActive(Enum.ModifierKey.Shift) then
        local gui = game.Players.LocalPlayer.PlayerGui or game:GetService("CoreGui")
        local mainFrame = gui:FindFirstChild("StudioExplorer")
        if mainFrame then
            mainFrame.Enabled = not mainFrame.Enabled
            if mainFrame.Enabled then
                showNotification("📂 Explorer показан", CONFIG.Colors.Success)
            else
                showNotification("📂 Explorer скрыт", CONFIG.Colors.Warning)
            end
        end
    end
    
    -- Delete для удаления выбранного объекта
    if input.KeyCode == Enum.KeyCode.Delete and selectedItem then
        local name = selectedItem.obj.Name
        selectedItem.obj:Destroy()
        showNotification("🗑️ Удалено: " .. name, CONFIG.Colors.Danger)
        selectedItem = nil
        -- Перезагружаем дерево
        local gui = game.Players.LocalPlayer.PlayerGui or game:GetService("CoreGui")
        local explorer = gui:FindFirstChild("StudioExplorer")
        if explorer then
            local scroll = explorer.MainFrame.Background.Content.ScrollFrame
            local layout = scroll.TreeLayout
            rebuildVisibleTree(scroll, layout, allData)
        end
    end
end)

-- ===== ИНИЦИАЛИЗАЦИЯ =====
local function init()
    local ui = createUI()
    
    -- Анимация появления
    ui.MainFrame.BackgroundTransparency = 0.05
    TweenService:Create(ui.MainFrame, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play()
    
    -- Обработчики
    ui.MinimizeBtn.MouseButton1Click:Connect(function()
        local content = ui.Content
        if content.Visible then
            TweenService:Create(ui.MainFrame, TweenInfo.new(0.2), {
                Size = UDim2.new(0, 360, 0, 35)
            }):Play()
            content.Visible = false
            ui.TitleText.Text = "📂 Explorer — [свернут]"
        else
            content.Visible = true
            TweenService:Create(ui.MainFrame, TweenInfo.new(0.2), {
                Size = CONFIG.WindowSize
            }):Play()
            ui.TitleText.Text = "📂 Explorer — " .. tostring(game.PlaceId)
        end
    end)
    
    ui.CloseBtn.MouseButton1Click:Connect(function()
        ui.ScreenGui:Destroy()
    end)
    
    ui.SearchBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            searchQuery = ui.SearchBox.Text
            rebuildVisibleTree(ui.ScrollFrame, ui.TreeLayout, allData)
        end
    end)
    
    ui.SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
        if ui.SearchBox.Text == "" then
            searchQuery = ""
            rebuildVisibleTree(ui.ScrollFrame, ui.TreeLayout, allData)
        end
    end)
    
    ui.SearchModeBtn.MouseButton1Click:Connect(function()
        if searchMode == "name" then
            searchMode = "content"
            ui.SearchModeBtn.Text = "📄"
            ui.SearchBox.PlaceholderText = "Поиск по содержимому..."
            showNotification("🔍 Поиск по содержимому скриптов", CONFIG.Colors.Warning)
        else
            searchMode = "name"
            ui.SearchModeBtn.Text = "📁"
            ui.SearchBox.PlaceholderText = "Поиск..."
            showNotification("📁 Поиск по именам", CONFIG.Colors.Success)
        end
    end)
    
    ui.LoadBtn.MouseButton1Click:Connect(function()
        loadEverything(ui)
    end)
    
    -- Перетаскивание окна
    local dragging = false
    local dragInput
    local dragStart
    local startPos
    
    ui.TitleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = ui.MainFrame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    ui.TitleBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
            local delta = input.Position - dragStart
            ui.MainFrame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    -- Правый клик на дереве
    ui.ScrollFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton2 then
            local x, y = input.Position.X, input.Position.Y
            -- Находим объект под курсором
            local mouse = game.Players.LocalPlayer:GetMouse()
            for _, btn in ipairs(ui.ScrollFrame:GetChildren()) do
                if btn:IsA("TextButton") then
                    local absPos = btn.AbsolutePosition
                    local absSize = btn.AbsoluteSize
                    if mouse.X >= absPos.X and mouse.X <= absPos.X + absSize.X and
                       mouse.Y >= absPos.Y and mouse.Y <= absPos.Y + absSize.Y then
                        local data = btn:GetAttribute("Data")
                        if data then
                            showContextMenu(data, mouse.X, mouse.Y, ui)
                            return
                        end
                    end
                end
            end
        end
    end)
    
    -- Клик по элементам дерева
    ui.ScrollFrame.MouseButton1Click:Connect(function()
        local mouse = game.Players.LocalPlayer:GetMouse()
        for _, btn in ipairs(ui.ScrollFrame:GetChildren()) do
            if btn:IsA("TextButton") then
                local absPos = btn.AbsolutePosition
                local absSize = btn.AbsoluteSize
                if mouse.X >= absPos.X and mouse.X <= absPos.X + absSize.X and
                   mouse.Y >= absPos.Y and mouse.Y <= absPos.Y + absSize.Y then
                    local data = btn:GetAttribute("Data")
                    if data then
                        selectedItem = data
                        
                        if data.isFolder then
                            data.isOpen = not data.isOpen
                            -- Сохраняем состояние
                            local key = data.path .. "/" .. data.obj.Name
                            openFolders[key] = data.isOpen
                            
                            -- Перезагружаем детей
                            if data.isOpen then
                                for _, child in ipairs(data.obj:GetChildren()) do
                                    local childData = collectData(child, data.depth + 1, key)
                                    if childData then
                                        table.insert(data.children, childData)
                                    end
                                end
                            else
                                data.children = {}
                            end
                            
                            rebuildVisibleTree(ui.ScrollFrame, ui.TreeLayout, allData)
                        else
                            -- Копируем содержимое
                            local content, type = getObjectContent(data.obj)
                            if content and content ~= "" then
                                if type == "image" then
                                    Clipboard(content)
                                    showNotification("🖼️ ID скопирован: " .. content, CONFIG.Colors.Success)
                                else
                                    Clipboard(content)
                                    showNotification("📋 Скопировано!", CONFIG.Colors.Success)
                                end
                            else
                                showNotification("❌ Нет содержимого для копирования", CONFIG.Colors.Danger)
                            end
                        end
                        return
                    end
                end
            end
        end
    end)
    
    -- Двойной клик для раскрытия папок
    ui.ScrollFrame.MouseButton2Click:Connect(function()
        -- Игнорируем двойной клик правой кнопкой
    end)
    
    -- Загружаем избранное при старте
    if isfile and isfile("studio_explorer_favorites.json") then
        local content = readfile("studio_explorer_favorites.json")
        if content then
            favorites = game:GetService("HttpService"):JSONDecode(content) or {}
            showNotification("⭐ Загружено " .. #favorites .. " избранных объектов", CONFIG.Colors.Warning)
        end
    end
    
    showNotification("📂 Нажмите 'Загрузить всё содержимое игры'", CONFIG.Colors.Accent)
end

-- Запуск
init()
