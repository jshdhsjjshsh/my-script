        end
    end
    
    local menu = Instance.new("Frame")
    menu.Name = "ContextMenu"
    menu.Size = UDim2.new(0, 200, 0, 0)
    menu.Position = UDim2.new(0, x, 0, y)
    menu.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
    menu.BackgroundTransparency = 0.05
