            Instance.new("UICorner", spawnBtn).CornerRadius = UDim.new(0, 4)
            spawnBtn.MouseButton1Click:Connect(function()
                for _, nftName in nftSel do local it = m("StringValue") it.Name = nftName it:SetAttribute("Favorite", true) it.Parent = inv end
