        local bcBox = cr("TextBox", PG, {Size = UDim2.new(1, -4, 0, 16), Position = UDim2.new(0, 2, 0, y), Text = tostring(battleCount), BackgroundColor3 = Color3.fromRGB(25, 25, 25), TextColor3 = txtCol, BorderSizePixel = 0, Font = Enum.Font.Gotham, TextSize = 7, ClearTextOnFocus = false})
        Instance.new("UICorner", bcBox).CornerRadius = UDim.new(0, 3) y = y + 18
        local botToggle = cr("TextButton", PG, {Size = UDim2.new(1, -4, 0, 18), Position = UDim2.new(0, 2, 0, y), Text = battleBot and "Bot: ON" or "Bot: OFF", BackgroundColor3 = battleBot and sc or Color3.fromRGB(80, 20, 20), TextColor3 = txtCol, BorderSizePixel = 0, Font = Enum.Font.Gotham, TextSize = 7})
        Instance.new("UICorner", botToggle).CornerRadius = UDim.new(0, 3) y = y + 20
