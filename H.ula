                cr("TextLabel", ff, {Size = UDim2.new(0.6, 0, 1, 0), Position = UDim2.new(0, 18, 0, 0), Text = nftName, TextColor3 = txtCol, BackgroundTransparency = 1, Font = Enum.Font.Gotham, TextSize = 7, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 63})
                cr("TextLabel", ff, {Size = UDim2.new(0.25, 0, 1, 0), Position = UDim2.new(0.55, 0, 0, 0), Text = "⭐" .. (gd and gd.Price or 0), TextColor3 = Color3.new(1, 0.8, 0), BackgroundTransparency = 1, Font = Enum.Font.Gotham, TextSize = 7, TextXAlignment = Enum.TextXAlignment.Right, ZIndex = 63})
                local cb = m("TextButton", ff) cb.Size = UDim2.new(0, 14, 0, 14) cb.Position = UDim2.new(1, -16, 0, 2) cb.Text = "" cb.BackgroundColor3 = Color3.fromRGB(35, 35, 35) cb.BorderSizePixel = 0 cb.Font = Enum.Font.GothamBold cb.TextSize = 7 cb.TextColor3 = sc cb.ZIndex = 63 cb.Name = "CBtn"
