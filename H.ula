            local tb = m("TextBox", f) tb.Size = UDim2.new(1, -16, 0, 24) tb.Position = UDim2.new(0, 8, 0, 32) tb.Text = "" tb.BackgroundColor3 = Color3.fromRGB(25, 25, 25) tb.TextColor3 = txtCol tb.BorderSizePixel = 0 tb.Font = Enum.Font.Gotham tb.TextSize = 9 tb.ZIndex = 61 Instance.new("UICorner", tb).CornerRadius = UDim.new(0, 4)
            local btn = m("TextButton", f) btn.Size = UDim2.new(1, -16, 0, 20) btn.Position = UDim2.new(0, 8, 0, 65) btn.Text = "SET" btn.BackgroundColor3 = sc btn.TextColor3 = Color3.new(0, 0, 0) btn.BorderSizePixel = 0 btn.Font = Enum.Font.GothamBold btn.TextSize = 9 btn.ZIndex = 61 Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
            btn.MouseButton1Click:Connect(function() local v = tonumber(tb.Text) if v then val.Value = v sg:Destroy() end end)
        end
        for _, c in ipairs({{"Set Stars", i._StarsValue}, {"Set TON", i._TONValue}, {"Set Gems", i._GemsValue}, {"Set Snowflakes", i._SnowflakesValue}}) do
