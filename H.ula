local function cr(c, p, props)
    local o = m(c)
    if p then o.Parent = p end
    if props then for k, v in pairs(props) do pcall(function() o[k] = v end) end end
    return o
end

local function round(num)
    local n = tostring(num)
    if #n > 9 then return string.format("%.1fB", num / 1000000000)
    elseif #n > 6 then return string.format("%.1fM", num / 1000000)
    elseif #n > 3 then return string.format("%.1fK", num / 1000)
    else return n end
end

local function notify(title, text, isMega)
    local nf = m("Frame", gui)
    nf.Size = UDim2.new(0, 280, 0, 50)
    nf.Position = UDim2.new(0.5, -140, 0, -55)
    nf.BackgroundColor3 = bgCol
    nf.BackgroundTransparency = 0.05
    nf.BorderSizePixel = 0
    nf.ZIndex = 100
    Instance.new("UICorner", nf).CornerRadius = UDim.new(0, 10)
    cr("TextLabel", nf, {Size = UDim2.new(1, -16, 0, 18), Position = UDim2.new(0, 8, 0, 4), Text = title, TextColor3 = isMega and Color3.fromRGB(255, 150, 50) or sc, BackgroundTransparency = 1, Font = Enum.Font.GothamBold, TextSize = 11, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 101})
    cr("TextLabel", nf, {Size = UDim2.new(1, -16, 0, 22), Position = UDim2.new(0, 8, 0, 22), Text = text, TextColor3 = txtCol, BackgroundTransparency = 1, Font = Enum.Font.Gotham, TextSize = 9, TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 101})
    if isMega then
        local snd = m("Sound", nf) snd.SoundId = "rbxassetid://9120386438" snd.Volume = 1 snd:Play() game.Debris:AddItem(snd, 3)
    end
    ts:Create(nf, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Position = UDim2.new(0.5, -140, 0, 8)}):Play()
    task.delay(3.5, function()
        ts:Create(nf, TweenInfo.new(0.3), {Position = UDim2.new(0.5, -140, 0, -55)}):Play()
        task.delay(0.3, function() nf:Destroy() end)
    end)
end

