            end
            nftBtn.MouseButton1Click:Connect(function() nftList.Visible = not nftList.Visible end)

            local patBtn = m("TextButton", f) patBtn.Size = UDim2.new(1, -16, 0, 16) patBtn.Position = UDim2.new(0, 8, 0, 116) patBtn.Text = selPat patBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25) patBtn.TextColor3 = txtCol patBtn.BorderSizePixel = 0 patBtn.Font = Enum.Font.Gotham patBtn.TextSize = 7 patBtn.ZIndex = 61
            Instance.new("UICorner", patBtn).CornerRadius = UDim.new(0, 3)
            local patList = m("ScrollingFrame", f) patList.Size = UDim2.new(1, -16, 0, 45) patList.Position = UDim2.new(0, 8, 0, 134) patList.CanvasSize = UDim2.new(0, 0, 0, #patterns * 18 + 10) patList.BackgroundColor3 = Color3.fromRGB(20, 20, 20) patList.BorderSizePixel = 0 patList.ScrollBarThickness = 2 patList.Visible = false patList.ZIndex = 62
            Instance.new("UICorner", patList).CornerRadius = UDim.new(0, 3)
            local py = 3
            for _, pn in patterns do
                local btn = m("TextButton", patList) btn.Size = UDim2.new(1, -6, 0, 16) btn.Position = UDim2.new(0, 3, 0, py) btn.Text = pn btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30) btn.TextColor3 = txtCol btn.BorderSizePixel = 0 btn.Font = Enum.Font.Gotham btn.TextSize = 7 btn.ZIndex = 63
                Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 2)
                btn.MouseButton1Click:Connect(function() selPat = pn patBtn.Text = pn patList.Visible = false end)
                py = py + 18
            end
            patBtn.MouseButton1Click:Connect(function() patList.Visible = not patList.Visible end)

            local bgBtn = m("TextButton", f) bgBtn.Size = UDim2.new(1, -16, 0, 16) bgBtn.Position = UDim2.new(0, 8, 0, 184) bgBtn.Text = selBg bgBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25) bgBtn.TextColor3 = txtCol bgBtn.BorderSizePixel = 0 bgBtn.Font = Enum.Font.Gotham bgBtn.TextSize = 7 bgBtn.ZIndex = 61
            Instance.new("UICorner", bgBtn).CornerRadius = UDim.new(0, 3)
            local bgList = m("ScrollingFrame", f) bgList.Size = UDim2.new(1, -16, 0, 40) bgList.Position = UDim2.new(0, 8, 0, 202) bgList.CanvasSize = UDim2.new(0, 0, 0, #backgrounds * 18 + 10) bgList.BackgroundColor3 = Color3.fromRGB(20, 20, 20) bgList.BorderSizePixel = 0 bgList.ScrollBarThickness = 2 bgList.Visible = false bgList.ZIndex = 62
            Instance.new("UICorner", bgList).CornerRadius = UDim.new(0, 3)
            local by = 3
            for _, bn in backgrounds do
                local btn = m("TextButton", bgList) btn.Size = UDim2.new(1, -6, 0, 16) btn.Position = UDim2.new(0, 3, 0, by) btn.Text = bn btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30) btn.TextColor3 = txtCol btn.BorderSizePixel = 0 btn.Font = Enum.Font.Gotham btn.TextSize = 7 btn.ZIndex = 63
                Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 2)
                btn.MouseButton1Click:Connect(function() selBg = bn bgBtn.Text = bn bgList.Visible = false end)
                by = by + 18
            end
            bgBtn.MouseButton1Click:Connect(function() bgList.Visible = not bgList.Visible end)

            local numBox = m("TextBox", f) numBox.Size = UDim2.new(0.28, -2, 0, 16) numBox.Position = UDim2.new(0, 8, 0, 248) numBox.Text = "1" numBox.BackgroundColor3 = Color3.fromRGB(25, 25, 25) numBox.TextColor3 = txtCol numBox.BorderSizePixel = 0 numBox.Font = Enum.Font.Gotham numBox.TextSize = 7 numBox.ZIndex = 61
            Instance.new("UICorner", numBox).CornerRadius = UDim.new(0, 3)
            local cntBox = m("TextBox", f) cntBox.Size = UDim2.new(0.28, -2, 0, 16) cntBox.Position = UDim2.new(0.35, 2, 0, 248) cntBox.Text = "1" cntBox.BackgroundColor3 = Color3.fromRGB(25, 25, 25) cntBox.TextColor3 = txtCol cntBox.BorderSizePixel = 0 cntBox.Font = Enum.Font.Gotham cntBox.TextSize = 7 cntBox.ZIndex = 61
            Instance.new("UICorner", cntBox).CornerRadius = UDim.new(0, 3)
            local spawnUBtn = m("TextButton", f) spawnUBtn.Size = UDim2.new(0.3, -2, 0, 16) spawnUBtn.Position = UDim2.new(0.7, 2, 0, 248) spawnUBtn.Text = "SPAWN" spawnUBtn.BackgroundColor3 = sc spawnUBtn.TextColor3 = Color3.new(0, 0, 0) spawnUBtn.BorderSizePixel = 0 spawnUBtn.Font = Enum.Font.GothamBold spawnUBtn.TextSize = 7 spawnUBtn.ZIndex = 61
            Instance.new("UICorner", spawnUBtn).CornerRadius = UDim.new(0, 3)
            spawnUBtn.MouseButton1Click:Connect(function()
                local cnt = tonumber(cntBox.Text) or 1 cnt = math.max(1, math.min(100, cnt))
                local num = tonumber(numBox.Text) or 1
                for j = 1, cnt do
                    local it = m("StringValue") it.Name = selNft it:SetAttribute("Unique", true) it:SetAttribute("Number", num + j - 1) it:SetAttribute("Pattern", selPat) it:SetAttribute("Background", selBg) it:SetAttribute("Favorite", true) it.Parent = inv
                end
                sg:Destroy()
            end)
        end)

        local fillIdx = cr("TextButton", PG, {Size = UDim2.new(1, -4, 0, 18), Position = UDim2.new(0, 2, 0, y), Text = "Fill Index", BackgroundColor3 = Color3.fromRGB(25, 25, 25), TextColor3 = txtCol, BorderSizePixel = 0, Font = Enum.Font.Gotham, TextSize = 7})
        Instance.new("UICorner", fillIdx).CornerRadius = UDim.new(0, 3) y = y + 20
        fillIdx.MouseButton1Click:Connect(function() for _, v in i._Index:GetChildren() do v.Value = v.Value + 1 end end)

        local hideBtn = cr("TextButton", PG, {Size = UDim2.new(1, -4, 0, 18), Position = UDim2.new(0, 2, 0, y), Text = "Hide Inv: OFF", BackgroundColor3 = Color3.fromRGB(25, 25, 25), TextColor3 = txtCol, BorderSizePixel = 0, Font = Enum.Font.Gotham, TextSize = 7})
        Instance.new("UICorner", hideBtn).CornerRadius = UDim.new(0, 3) y = y + 20
        hideBtn.MouseButton1Click:Connect(function() hideInv = not hideInv hideBtn.Text = hideInv and "Hide Inv: ON" or "Hide Inv: OFF" for _, v in i.PlayerGui.MainGui.Pages.Profile.MainFrame:GetDescendants() do if v.Name == "Inventory" then v.Visible = not hideInv end end end)
        PG.CanvasSize = UDim2.new(0, 0, 0, y + 15)

    elseif sTab == "Extra" then
        cr("TextLabel", PG, {Size = UDim2.new(1, 0, 0, 13), Position = UDim2.new(0, 4, 0, y), Text = "EXTRA FUNCTIONS", TextColor3 = sc, BackgroundTransparency = 1, Font = Enum.Font.GothamBold, TextSize = 9}) y = y + 16

        local extraBtns = {
            {"Drop Stats", function()
                local ds = m("ScreenGui", i.PlayerGui)
                local df = m("Frame", ds) df.Size = UDim2.new(0, 240, 0, 280) df.Position = UDim2.new(0.5, -120, 0.5, -140) df.BackgroundColor3 = bgCol df.BorderSizePixel = 0 df.ZIndex = 60
                Instance.new("UICorner", df).CornerRadius = UDim.new(0, 8)
                local dt = m("Frame", df) dt.Size = UDim2.new(1, 0, 0, 24) dt.BackgroundColor3 = sc dt.BorderSizePixel = 0 dt.ZIndex = 61
                Instance.new("UICorner", dt).CornerRadius = UDim.new(0, 8)
                cr("TextLabel", dt, {Size = UDim2.new(1, -30, 1, 0), Position = UDim2.new(0, 6, 0, 0), Text = "Drop Stats", TextColor3 = Color3.new(0, 0, 0), BackgroundTransparency = 1, Font = Enum.Font.GothamBold, TextSize = 9, ZIndex = 62})
                local dc = m("TextButton", dt, {Size = UDim2.new(0, 16, 0, 16), Position = UDim2.new(1, -20, 0, 4), Text = "✕", TextColor3 = Color3.new(0, 0, 0), BackgroundColor3 = Color3.fromRGB(255, 255, 255, 0.2), BorderSizePixel = 0, Font = Enum.Font.GothamBold, TextSize = 7, ZIndex = 62})
                Instance.new("UICorner", dc).CornerRadius = UDim.new(0, 3) dc.MouseButton1Click:Connect(function() ds:Destroy() end)
                local dss = m("ScrollingFrame", df) dss.Size = UDim2.new(1, -8, 1, -30) dss.Position = UDim2.new(0, 4, 0, 28) dss.CanvasSize = UDim2.new(0, 0, 0, 4000) dss.BackgroundTransparency = 1 dss.BorderSizePixel = 0 dss.ScrollBarThickness = 2 dss.ZIndex = 61
                local dy = 3
                local sorted = {} for k, v in dropStats do table.insert(sorted, {name = k, count = v}) end table.sort(sorted, function(a, b) return a.count > b.count end)
                for _, s in sorted do
                    local ff = m("Frame", dss) ff.Size = UDim2.new(1, -6, 0, 15) ff.Position = UDim2.new(0, 3, 0, dy) ff.BackgroundColor3 = Color3.fromRGB(25, 25, 25) ff.BorderSizePixel = 0 ff.ZIndex = 62
                    Instance.new("UICorner", ff).CornerRadius = UDim.new(0, 2)
                    cr("TextLabel", ff, {Size = UDim2.new(0.7, 0, 1, 0), Position = UDim2.new(0, 3, 0, 0), Text = s.name, TextColor3 = txtCol, BackgroundTransparency = 1, Font = Enum.Font.Gotham, TextSize = 6, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 63})
                    cr("TextLabel", ff, {Size = UDim2.new(0.25, 0, 1, 0), Position = UDim2.new(0.72, 0, 0, 0), Text = "x" .. s.count, TextColor3 = sc, BackgroundTransparency = 1, Font = Enum.Font.Gotham, TextSize = 6, TextXAlignment = Enum.TextXAlignment.Right, ZIndex = 63})
                    dy = dy + 17
                end
                dss.CanvasSize = UDim2.new(0, 0, 0, dy + 5)
            end},
            {"Open Battlepass", function() ev.GUI:Fire("OpenPage", "Battlepass") end},
            {"Dump Remotes (F9)", function() print("=== REMOTES ===") for _, v in u:GetChildren() do print(v.Name, v.ClassName) end end},
            {"Auto Daily", function() pcall(function() ev.Daily:InvokeServer() end) notify("Daily", "Claimed!", false) end},
            {"Teleport Spawn", function() i.Character:MoveTo(Vector3.new(0, 0, 0)) end},
            {"Anti AFK: " .. (antiAfk and "ON" or "OFF"), function() antiAfk = not antiAfk end},
        }

        for _, btnData in ipairs(extraBtns) do
            local btn = cr("TextButton", PG, {Size = UDim2.new(1, -4, 0, 20), Position = UDim2.new(0, 2, 0, y), Text = btnData[1], BackgroundColor3 = Color3.fromRGB(25, 25, 25), TextColor3 = txtCol, BorderSizePixel = 0, Font = Enum.Font.Gotham, TextSize = 7})
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 3) y = y + 22
            btn.MouseButton1Click:Connect(btnData[2])
        end
        PG.CanvasSize = UDim2.new(0, 0, 0, y + 15)

    elseif sTab == "Info" then
        cr("TextLabel", PG, {Size = UDim2.new(1, 0, 0, 13), Position = UDim2.new(0, 4, 0, y), Text = "INFO", TextColor3 = sc, BackgroundTransparency = 1, Font = Enum.Font.GothamBold, TextSize = 9}) y = y + 16
        cr("ImageLabel", PG, {Size = UDim2.new(0, 44, 0, 44), Position = UDim2.new(0, 4, 0, y), BackgroundTransparency = 1, Image = "rbxthumb://type=AvatarHeadShot&id=" .. creatorId .. "&w=48&h=48"}) y = y + 48
        cr("TextLabel", PG, {Size = UDim2.new(1, 0, 0, 14), Position = UDim2.new(0, 4, 0, y), Text = "Creator: " .. creatorName, TextColor3 = sc, BackgroundTransparency = 1, Font = Enum.Font.GothamBold, TextSize = 10}) y = y + 18
        cr("TextLabel", PG, {Size = UDim2.new(1, 0, 1, 0), Position = UDim2.new(0, 4, 0, y), Text = "💼 Cases - Auto open/sell/fav\n🥊 Battle - Auto battles + bot\n🔄 Fuse/Craft - Auto fuse & craft\n🎄 Xmas - Cases & spin\n🎲 Dice - PvP farm\n💻 Local - Balance, spawn\n🔧 Extra - Stats, dump, daily\n\nActive: Fast Upgrade, Anti AFK\nNotify + sound on >1B drop", TextColor3 = Color3.new(0.7, 0.7, 0.7), BackgroundTransparency = 1, Font = Enum.Font.Gotham, TextSize = 8, TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left})
        PG.CanvasSize = UDim2.new(0, 0, 0, y + 15)
    end
end

loadTab()
