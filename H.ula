local function caseBtn(n, selectedList)
    local cd = inf.Cases[n]
    local f = cr("Frame", nil, {Size = UDim2.new(1, -4, 0, 28), BackgroundColor3 = Color3.fromRGB(20, 20, 20), BackgroundTransparency = 0.3, BorderSizePixel = 0})
    Instance.new("UICorner", f).CornerRadius = UDim.new(0, 5)
    if cd and cd.Image then cr("ImageLabel", f, {Size = UDim2.new(0, 24, 0, 24), Position = UDim2.new(0, 3, 0, 2), BackgroundTransparency = 1, Image = "rbxassetid://" .. cd.Image}) end
    local currency = cd and cd.TON and "💠" or cd and cd.GEMS and "💎" or "⭐"
    local price = cd and cd.Price or 0
    cr("TextLabel", f, {Size = UDim2.new(1, -70, 1, 0), Position = UDim2.new(0, 30, 0, 0), Text = n, TextColor3 = txtCol, BackgroundTransparency = 1, Font = Enum.Font.GothamBold, TextSize = 9, TextXAlignment = Enum.TextXAlignment.Left})
    cr("TextLabel", f, {Size = UDim2.new(0, 45, 1, 0), Position = UDim2.new(1, -70, 0, 0), Text = currency .. price, TextColor3 = Color3.new(1, 0.8, 0), BackgroundTransparency = 1, Font = Enum.Font.Gotham, TextSize = 8, TextXAlignment = Enum.TextXAlignment.Right})
    local addBtn = cr("TextButton", f, {Size = UDim2.new(0, 22, 0, 22), Position = UDim2.new(1, -24, 0, 3), Text = "+", TextColor3 = txtCol, BackgroundColor3 = Color3.fromRGB(35, 35, 35), BorderSizePixel = 0, Font = Enum.Font.GothamBold, TextSize = 12})
    Instance.new("UICorner", addBtn).CornerRadius = UDim.new(0, 4)
    if table.find(selectedList, n) then addBtn.Text = "✓" addBtn.BackgroundColor3 = sc end
    addBtn.MouseButton1Click:Connect(function()
        local idx = table.find(selectedList, n)
        if idx then table.remove(selectedList, idx) addBtn.Text = "+" addBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        else table.insert(selectedList, n) addBtn.Text = "✓" addBtn.BackgroundColor3 = sc end
    end)
    return f
end

function loadTab()
    for _, v in PG:GetChildren() do v:Destroy() end
    local y = 3

    if sTab == "Cases" then
        cr("TextLabel", PG, {Size = UDim2.new(1, 0, 0, 13), Position = UDim2.new(0, 4, 0, y), Text = "CASES", TextColor3 = sc, BackgroundTransparency = 1, Font = Enum.Font.GothamBold, TextSize = 9}) y = y + 16
        local statLab = cr("TextLabel", PG, {Size = UDim2.new(1, 0, 0, 11), Position = UDim2.new(0, 4, 0, y), Text = "Opened: " .. openedCount .. " | Sold: " .. soldCount, TextColor3 = Color3.new(0.7, 0.7, 0.7), BackgroundTransparency = 1, Font = Enum.Font.Gotham, TextSize = 7}) y = y + 13
        for _, n in cases do local f = caseBtn(n, selCase) f.Position = UDim2.new(0, 2, 0, y) f.Parent = PG y = y + 30 end
        y = y + 2

        local as = cr("TextButton", PG, {Size = UDim2.new(1, -4, 0, 20), Position = UDim2.new(0, 2, 0, y), Text = autoSell and "Sell: ON" or "Sell: OFF", BackgroundColor3 = autoSell and sc or Color3.fromRGB(80, 20, 20), TextColor3 = txtCol, BorderSizePixel = 0, Font = Enum.Font.Gotham, TextSize = 8})
        Instance.new("UICorner", as).CornerRadius = UDim.new(0, 3) as:SetAttribute("static", true) y = y + 22
        as.MouseButton1Click:Connect(function() autoSell = not autoSell as.Text = autoSell and "Sell: ON" or "Sell: OFF" as.BackgroundColor3 = autoSell and sc or Color3.fromRGB(80, 20, 20) end)

        local favBtn = cr("TextButton", PG, {Size = UDim2.new(1, -4, 0, 20), Position = UDim2.new(0, 2, 0, y), Text = "Favorite: SELECT", BackgroundColor3 = Color3.fromRGB(100, 80, 0), TextColor3 = txtCol, BorderSizePixel = 0, Font = Enum.Font.Gotham, TextSize = 8})
        Instance.new("UICorner", favBtn).CornerRadius = UDim.new(0, 3) favBtn:SetAttribute("static", true) y = y + 22
        favBtn.MouseButton1Click:Connect(function()
            local fGui = m("ScreenGui", i.PlayerGui) fGui.Name = "FavWindow"
            local bg = m("Frame", fGui) bg.Size = UDim2.new(0, 290, 0, 380) bg.Position = UDim2.new(0.5, -145, 0.5, -190) bg.BackgroundColor3 = bgCol bg.BorderSizePixel = 0 bg.ZIndex = 50
            Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 10)
            local ft = m("Frame", bg) ft.Size = UDim2.new(1, 0, 0, 26) ft.BackgroundColor3 = sc ft.BorderSizePixel = 0 ft.ZIndex = 51
            Instance.new("UICorner", ft).CornerRadius = UDim.new(0, 10)
            cr("TextLabel", ft, {Size = UDim2.new(1, -36, 1, 0), Position = UDim2.new(0, 6, 0, 0), Text = "Select Favorites", TextColor3 = Color3.new(0, 0, 0), BackgroundTransparency = 1, Font = Enum.Font.GothamBold, TextSize = 10, ZIndex = 52})
            local fc = m("TextButton", ft, {Size = UDim2.new(0, 18, 0, 18), Position = UDim2.new(1, -22, 0, 4), Text = "✕", TextColor3 = Color3.new(0, 0, 0), BackgroundColor3 = Color3.fromRGB(255, 255, 255, 0.2), BorderSizePixel = 0, Font = Enum.Font.GothamBold, TextSize = 9, ZIndex = 52})
            Instance.new("UICorner", fc).CornerRadius = UDim.new(0, 3) fc.MouseButton1Click:Connect(function() fGui:Destroy() end)

            local allNftsInCases = {}
            for _, cn in pairs(selCase) do
                if inf.Cases[cn] and inf.Cases[cn].Content then
                    for nftName, nftData in pairs(inf.Cases[cn].Content) do
                        if not allNftsInCases[nftName] then
                            local gd = inf.Gifts[nftName]
                            allNftsInCases[nftName] = {
                                chance = type(nftData) == "number" and nftData or 0.01,
                                price = gd and gd.Price or 0,
                                image = gd and gd.Image or 0
                            }
                        end
                    end
                end
            end

            local fs = m("ScrollingFrame", bg) fs.Size = UDim2.new(1, -10, 1, -70) fs.Position = UDim2.new(0, 5, 0, 30) fs.CanvasSize = UDim2.new(0, 0, 0, 4000) fs.BackgroundTransparency = 1 fs.BorderSizePixel = 0 fs.ScrollBarThickness = 2 fs.ZIndex = 51
            local fy = 3
            local allBtn = m("TextButton", bg) allBtn.Size = UDim2.new(1, -10, 0, 18) allBtn.Position = UDim2.new(0, 5, 0, 340) allBtn.Text = "Select All" allBtn.BackgroundColor3 = sc allBtn.TextColor3 = Color3.new(0, 0, 0) allBtn.BorderSizePixel = 0 allBtn.Font = Enum.Font.GothamBold allBtn.TextSize = 9 allBtn.ZIndex = 51
            Instance.new("UICorner", allBtn).CornerRadius = UDim.new(0, 3)
            allBtn.MouseButton1Click:Connect(function()
                favList = {} for nftName, _ in pairs(allNftsInCases) do table.insert(favList, nftName) end
                for _, v in fs:GetChildren() do if v:IsA("Frame") and v:FindFirstChild("CheckBtn") then v.CheckBtn.Text = "✓" v.CheckBtn.BackgroundColor3 = sc end end
            end)
            local saveBtn = m("TextButton", bg) saveBtn.Size = UDim2.new(1, -10, 0, 20) saveBtn.Position = UDim2.new(0, 5, 0, 360) saveBtn.Text = "Save & Close" saveBtn.BackgroundColor3 = sc saveBtn.TextColor3 = Color3.new(0, 0, 0) saveBtn.BorderSizePixel = 0 saveBtn.Font = Enum.Font.GothamBold saveBtn.TextSize = 9 saveBtn.ZIndex = 51
            Instance.new("UICorner", saveBtn).CornerRadius = UDim.new(0, 3) saveBtn.MouseButton1Click:Connect(function() fGui:Destroy() end)

            if next(allNftsInCases) == nil then
                cr("TextLabel", fs, {Size = UDim2.new(1, 0, 0, 30), Position = UDim2.new(0, 0, 0, 100), Text = "Select cases first!\nNo NFTs to show.", TextColor3 = Color3.new(0.7, 0.7, 0.7), BackgroundTransparency = 1, Font = Enum.Font.Gotham, TextSize = 10, TextXAlignment = Enum.TextXAlignment.Center})
            else
                for nftName, nftData in pairs(allNftsInCases) do
                    local ff = m("Frame", fs) ff.Size = UDim2.new(1, -6, 0, 22) ff.Position = UDim2.new(0, 3, 0, fy) ff.BackgroundColor3 = Color3.fromRGB(22, 22, 22) ff.BorderSizePixel = 0 ff.ZIndex = 52
                    Instance.new("UICorner", ff).CornerRadius = UDim.new(0, 3)
                    if nftData.image ~= 0 then cr("ImageLabel", ff, {Size = UDim2.new(0, 18, 0, 18), Position = UDim2.new(0, 2, 0, 2), BackgroundTransparency = 1, Image = "rbxassetid://" .. nftData.image, ZIndex = 53}) end
                    cr("TextLabel", ff, {Size = UDim2.new(0.45, 0, 1, 0), Position = UDim2.new(0, 22, 0, 0), Text = nftName, TextColor3 = txtCol, BackgroundTransparency = 1, Font = Enum.Font.Gotham, TextSize = 7, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 53})
                    cr("TextLabel", ff, {Size = UDim2.new(0.25, 0, 1, 0), Position = UDim2.new(0.48, 0, 0, 0), Text = "⭐" .. nftData.price, TextColor3 = Color3.new(1, 0.8, 0), BackgroundTransparency = 1, Font = Enum.Font.Gotham, TextSize = 7, TextXAlignment = Enum.TextXAlignment.Right, ZIndex = 53})
                    local cb = m("TextButton", ff) cb.Size = UDim2.new(0, 16, 0, 16) cb.Position = UDim2.new(1, -18, 0, 3) cb.Text = "" cb.BackgroundColor3 = Color3.fromRGB(30, 30, 30) cb.BorderSizePixel = 0 cb.Font = Enum.Font.GothamBold cb.TextSize = 8 cb.TextColor3 = sc cb.ZIndex = 53 cb.Name = "CheckBtn"
                    Instance.new("UICorner", cb).CornerRadius = UDim.new(0, 3)
                    if table.find(favList, nftName) then cb.Text = "✓" cb.BackgroundColor3 = sc end
                    cb.MouseButton1Click:Connect(function()
                        local idx = table.find(favList, nftName)
                        if idx then table.remove(favList, idx) cb.Text = "" cb.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
                        else table.insert(favList, nftName) cb.Text = "✓" cb.BackgroundColor3 = sc end
                    end)
                    fy = fy + 24
                end
            end
            fs.CanvasSize = UDim2.new(0, 0, 0, fy + 5)
        end)

        local st = cr("TextButton", PG, {Size = UDim2.new(1, -4, 0, 26), Position = UDim2.new(0, 2, 0, y), Text = "START", BackgroundColor3 = sc, TextColor3 = Color3.new(0, 0, 0), BorderSizePixel = 0, Font = Enum.Font.GothamBold, TextSize = 11})
        Instance.new("UICorner", st).CornerRadius = UDim.new(0, 4) st:SetAttribute("static", true) y = y + 28
        st.MouseButton1Click:Connect(function()
            if not running then
                if #selCase == 0 then return end
                running = true st.Text = "STOP" st.BackgroundColor3 = Color3.fromRGB(180, 30, 30)
                task.spawn(function()
                    while running do
                        for _, cn in selCase do
                            if not running then break end
                            pcall(function() ev.OpenCase:InvokeServer(cn, openCount) end)
                            openedCount = openedCount + openCount statLab.Text = "Opened: " .. openedCount .. " | Sold: " .. soldCount
                            wait(0.08)
                            for _, it in inv:GetChildren() do
                                if it:IsA("StringValue") and inf.Gifts[it.Name] then
                                    local price = inf.Gifts[it.Name].Price or 0
                                    dropStats[it.Name] = (dropStats[it.Name] or 0) + 1
                                    if table.find(favList, it.Name) then
                                        pcall(function() ev.Favorite:InvokeServer(it, true) end)
                                    elseif autoSell then
                                        pcall(function() ev.Inventory:FireServer("Sell", it) soldCount = soldCount + 1 statLab.Text = "Opened: " .. openedCount .. " | Sold: " .. soldCount end)
                                    end
                                    if price >= 1000000000 then notify("MEGA DROP!", it.Name .. " - " .. price .. "⭐", true) end
                                end
                            end
                        end
                        wait(0.15)
                    end
                    running = false st.Text = "START" st.BackgroundColor3 = sc
                end)
            else running = false st.Text = "START" st.BackgroundColor3 = sc end
        end)
        PG.CanvasSize = UDim2.new(0, 0, 0, y + 15)

    elseif sTab == "Battle" then
        cr("TextLabel", PG, {Size = UDim2.new(1, 0, 0, 13), Position = UDim2.new(0, 4, 0, y), Text = "BATTLE", TextColor3 = sc, BackgroundTransparency = 1, Font = Enum.Font.GothamBold, TextSize = 9}) y = y + 16
        for _, n in cases do local f = caseBtn(n, selBattleCase) f.Position = UDim2.new(0, 2, 0, y) f.Parent = PG y = y + 30 end
        y = y + 2
