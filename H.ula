            Instance.new("UICorner", ft).CornerRadius = UDim.new(0, 10)
            cr("TextLabel", ft, {Size = UDim2.new(1, -36, 1, 0), Position = UDim2.new(0, 6, 0, 0), Text = "Spawn NFT", TextColor3 = Color3.new(0, 0, 0), BackgroundTransparency = 1, Font = Enum.Font.GothamBold, TextSize = 10, ZIndex = 62})
            local fc = m("TextButton", ft, {Size = UDim2.new(0, 18, 0, 18), Position = UDim2.new(1, -22, 0, 4), Text = "✕", TextColor3 = Color3.new(0, 0, 0), BackgroundColor3 = Color3.fromRGB(255, 255, 255, 0.2), BorderSizePixel = 0, Font = Enum.Font.GothamBold, TextSize = 9, ZIndex = 62})
