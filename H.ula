        local function setVal(title, val)
            local sg = m("ScreenGui", i.PlayerGui)
            local f = m("Frame", sg) f.Size = UDim2.new(0, 200, 0, 95) f.Position = UDim2.new(0.5, -100, 0.5, -47) f.BackgroundColor3 = bgCol f.BorderSizePixel = 0 f.ZIndex = 60
