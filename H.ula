                        ev.Battles:InvokeServer("Create", cl, {}) ev.Btl:Fire(cl)
                        if battleBot then wait(0.5) ev.Battles:InvokeServer("CallABot") end
                        wait(0.5)
                    end
                    runningBattle = false st2.Text = "START BATTLE" st2.BackgroundColor3 = sc
